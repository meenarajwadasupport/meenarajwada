# ─────────────────────────────────────────────────────────────
# MEENA RAJWADA — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file with real keys.
# This file contains placeholders only — safe to commit.
# ─────────────────────────────────────────────────────────────

# ── Frontend (VITE_ prefix — exposed to browser, anon key only) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GA_ID=G-XXXXXXXXXX
VITE_CASHFREE_MODE=sandbox

# ── Server-only — set these in Vercel Environment Variables ──
# These are NEVER exposed to the browser (no VITE_ prefix)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_WEBHOOK_SECRET=your_cashfree_webhook_secret
CASHFREE_ENV=sandbox
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...replace with full JSON..."}
GOOGLE_SHEET_ID=your_google_sheet_id_from_url
SETUP_SECRET=generate_a_long_random_string_here
